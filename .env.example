# Render จะมี DATABASE_URL อัตโนมัติเมื่อเชื่อม PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-secret

# Google OAuth / Login with Gmail
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://bidmarket-lxou.onrender.com/auth/google/callback

# Gmail ที่ต้องการให้เป็น Admin คั่นหลายบัญชีด้วย comma
ADMIN_EMAILS=tokizawa1412@gmail.com
