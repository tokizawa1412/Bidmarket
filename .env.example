NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string
# ใส่จาก Render PostgreSQL > External Database URL หรือ Internal Database URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ถ้าใช้ Render PostgreSQL ปกติไม่ต้องแก้
PGSSLMODE=require
# Optional: เปิดใช้ AI วิเคราะห์รูปสินค้า
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
# Google Login / Gmail OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-render-app.onrender.com/auth/google/callback
ADMIN_EMAILS=your-admin@gmail.com

# Production file storage: Cloudinary (recommended free start) or Cloudflare R2 / S3-compatible
# auto = use Cloudinary if Cloudinary variables are present, else R2 if configured, else local fallback
STORAGE_DRIVER=auto
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET=bidmarket-files
# R2_PUBLIC_URL=https://cdn.example.com
MAX_UPLOAD_MB=300

# Discord Admin Webhook Alerts
# สร้าง Webhook ใน Discord แล้วใส่ URL นี้ใน Render Environment
DISCORD_NOTIFY_ENABLED=true
DISCORD_WEBHOOK_URL=
# ถ้าต้องการแยกห้องสำหรับกลางไอเทม ให้ใส่ค่านี้ ระบบจะใช้ค่านี้ก่อน DISCORD_WEBHOOK_URL
DISCORD_ITEM_ESCROW_WEBHOOK_URL=
DISCORD_WEBHOOK_NAME=BidMarket Admin Alert
DISCORD_WEBHOOK_AVATAR_URL=
